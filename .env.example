RAINDROP_TOKEN=$RAINDROP_TOKEN
LLM_PROVIDER=#gemini|openai|xai
LLM_MODEL=$MODEL_NAME
# Required for Gemini-backed models such as gemini-2.5-flash.
GEMINI_API_KEY=$GEMINI_API_KEY
# Required for OpenAI-backed models such as gpt-5.4-mini.
OPENAI_API_KEY=$OPENAI_API_KEY
# Required for xAI-backed models and for x.com links, which are always summarized with xAI Grok.
XAI_API_KEY=$XAI_API_KEY
SUMMARIZE_CONCURRENCY=2
PYTHON_BACKEND_URL=http://127.0.0.1:8000
